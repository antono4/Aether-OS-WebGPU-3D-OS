# ===========================================
# Aether OS - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ===========================================
# AI PROVIDERS
# ===========================================

# Anthropic Claude API
# Get key at: https://console.anthropic.com/
CLAUDE_API_KEY=

# OpenAI API
# Get key at: https://platform.openai.com/
OPENAI_API_KEY=

# Google Gemini API
# Get key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Default AI Provider
# Options: 'claude' | 'openai' | 'gemini' | 'ollama'
DEFAULT_AI_PROVIDER=claude

# ===========================================
# OLLAMA (Local LLM)
# ===========================================

# Ollama endpoint
OLLAMA_ENDPOINT=http://localhost:11434

# Default model
OLLAMA_MODEL=llama3

# Available models
# Run: ollama pull llama3
# Run: ollama pull mistral
# Run: ollama pull phi3

# ===========================================
# COLLABORATION
# ===========================================

# WebSocket server URL for real-time collaboration
COLLAB_WS_URL=

# Session timeout in milliseconds (default: 1 hour)
COLLAB_SESSION_TIMEOUT=3600000

# ===========================================
# STORAGE
# ===========================================

# Storage backend type
# Options: 'indexeddb' | 'sqlite' | 'memory'
STORAGE_TYPE=indexeddb

# Enable encryption for local storage
ENABLE_ENCRYPTION=false

# Encryption passphrase (if enabled)
# ENCRYPTION_KEY=your-secure-passphrase

# Maximum storage size in MB
MAX_STORAGE_MB=500

# ===========================================
# PERFORMANCE
# ===========================================

# Enable WebGPU renderer (if supported)
ENABLE_WEBGPU=true

# Maximum nodes to render
MAX_RENDER_NODES=10000

# Enable performance monitoring
ENABLE_MONITORING=true

# Frame rate target
TARGET_FPS=60

# ===========================================
# ANALYTICS & TELEMETRY
# ===========================================

# Enable anonymous analytics
ENABLE_ANALYTICS=false

# Enable error telemetry
ENABLE_TELEMETRY=false

# ===========================================
# FEATURES
# ===========================================

# Enable experimental features
ENABLE_EXPERIMENTAL=false

# Enable voice input
ENABLE_VOICE=true

# Enable shader playground
ENABLE_SHADERS=true

# ===========================================
# SECURITY
# ===========================================

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Session secret for JWT tokens
SESSION_SECRET=change-this-to-a-random-string

# ===========================================
# OAUTH / SSO
# ===========================================

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Callback URL
OAUTH_CALLBACK_URL=http://localhost:5173/auth/callback

# ===========================================
# PAYMENTS (Stripe)
# ===========================================

# Stripe API keys
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ===========================================
# SYNC
# ===========================================

# Cross-device sync server URL
SYNC_SERVER_URL=

# Sync interval in seconds
SYNC_INTERVAL=30

# ===========================================
# LOGGING
# ===========================================

# Log level
# Options: 'debug' | 'info' | 'warn' | 'error'
LOG_LEVEL=info

# ===========================================
# DEVELOPMENT
# ===========================================

# Node environment
NODE_ENV=development

# Vite port
VITE_PORT=5173

# Enable hot module replacement
HMR=true
